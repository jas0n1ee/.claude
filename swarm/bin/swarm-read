#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=swarm-env.sh
. "$SCRIPT_DIR/swarm-env.sh"

IDENTITY="${1:-${SWARM_IDENTITY:-orchestrator}}"
SESSION="${SWARM_SESSION:-}"

if [ -z "$SESSION" ]; then
  swarm_require_tmux
  SESSION="$(swarm_session)"
fi

swarm_ensure_runtime "$SESSION"
INBOX_DIR="$(swarm_inbox_dir "$SESSION" "$IDENTITY")"

if [ ! -d "$INBOX_DIR" ]; then
  echo "Inbox does not exist: $INBOX_DIR"
  exit 0
fi

shopt -s nullglob
FILES=("$INBOX_DIR"/*.msg)
shopt -u nullglob

if [ "${#FILES[@]}" -eq 0 ]; then
  echo "No unread messages in $INBOX_DIR"
  exit 0
fi

for f in "${FILES[@]}"; do
  SENDER="$(basename "$f" .msg)"
  echo "[$SENDER] $(cat "$f")"
done
