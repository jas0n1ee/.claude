#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=swarm-env.sh
. "$SCRIPT_DIR/swarm-env.sh"

swarm_require_tmux

if ! command -v codex >/dev/null 2>&1; then
  echo "codex is not installed or not on PATH" >&2
  exit 1
fi

SESSION="$(swarm_session)"
CURRENT_WINDOW="$(swarm_window)"
CURRENT_PATH="$(swarm_pane_path)"
HAS_ORCHESTRATOR="$(swarm_has_orchestrator "$SESSION")"
WORKDIR="${1:-$CURRENT_PATH}"
PROMPT_FILE="$SWARM_PROMPTS_DIR/codex-orchestrator.md"

swarm_ensure_runtime "$SESSION"
mkdir -p "$SWARM_PROMPTS_DIR"

if [ ! -f "$PROMPT_FILE" ]; then
  echo "Missing prompt file: $PROMPT_FILE" >&2
  exit 1
fi

if [ "$HAS_ORCHESTRATOR" = "0" ]; then
  tmux rename-window -t "$SESSION:$CURRENT_WINDOW" orchestrator
  CURRENT_WINDOW="orchestrator"
fi

if [ "$CURRENT_WINDOW" != "orchestrator" ]; then
  echo "orchestrator already exists in session '$SESSION'" >&2
  echo "Current window is '$CURRENT_WINDOW'; refusing to start a second orchestrator" >&2
  exit 1
fi

export SWARM_SESSION="$SESSION"
export SWARM_ROLE="orchestrator"
export SWARM_IDENTITY="orchestrator"
export SWARM_INBOX="$(swarm_inbox_dir "$SESSION" "orchestrator")"

PROMPT_CONTENT="$(cat "$PROMPT_FILE")"
PROMPT="$(cat <<EOF
You are booting into Swarm Orchestrator mode.

Runtime:
- SWARM_REPO_ROOT=$SWARM_REPO_ROOT
- SWARM_RUNTIME_ROOT=$SWARM_RUNTIME_ROOT
- SWARM_SESSION=$SWARM_SESSION
- SWARM_ROLE=$SWARM_ROLE
- SWARM_IDENTITY=$SWARM_IDENTITY
- SWARM_INBOX=$SWARM_INBOX
- Current tmux window must remain named orchestrator.

$PROMPT_CONTENT
EOF
)"

exec codex -C "$WORKDIR" --no-alt-screen "$PROMPT"
