#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=swarm-env.sh
. "$SCRIPT_DIR/swarm-env.sh"

usage() {
  echo "Usage: $(basename "$0") <sender> [identity]" >&2
}

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  usage
  exit 1
fi

SENDER="$1"
IDENTITY="${2:-${SWARM_IDENTITY:-orchestrator}}"
SESSION="${SWARM_SESSION:-}"

if [ -z "$SESSION" ]; then
  swarm_require_tmux
  SESSION="$(swarm_session)"
fi

FILE="$(swarm_message_file "$SESSION" "$IDENTITY" "$SENDER")"
if [ ! -f "$FILE" ]; then
  echo "Message not found: $FILE" >&2
  exit 1
fi

rm "$FILE"
echo "Acknowledged $FILE"
